# SujudSense environment template
# Copy this file to .env and customize as needed.

# Embedding and vector store settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./chroma_db
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_K=3

# LLM settings
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=250

# Cloud LLM provider token for langchain-groq
GROQ_API_KEY=your-groq-api-key-here

# Query safety firewall threshold
FIREWALL_THRESHOLD=1.4

# Logger settings
LOG_LEVEL=INFO
